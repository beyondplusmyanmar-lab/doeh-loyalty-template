# ─────────────────────────────────────────────────────────────────────────────
# DOEH Loyalty Broker — environment. Copy to `.env` (gitignored) and fill in.
# These are SERVER secrets. They never reach the app and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# Where to proxy. Use the sandbox while testing; api.doehpos.com for production.
DOEH_API_BASE=https://sandbox-api.doehpos.com

# The secret merchant key the broker holds on the app's behalf.
# Sandbox: sk_test_…   Production: sk_live_…   NEVER put this in the app.
DOEH_API_KEY=

# Strong random secret used to sign access tokens (e.g. `openssl rand -hex 32`).
BROKER_JWT_SECRET=

# STUB device auth — the app sends this to /auth/token. Replace the check in
# src/server.js with your real device/user authentication before going live.
DEVICE_SHARED_SECRET=

# Token lifetimes (seconds). Keep the access token short.
ACCESS_TTL_SECONDS=300
REFRESH_TTL_SECONDS=2592000

# Only paths under this prefix are proxied (defense in depth).
ALLOWED_PATH_PREFIX=/v1/loyalty

PORT=8787
