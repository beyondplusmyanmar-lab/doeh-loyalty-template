# ─────────────────────────────────────────────────────────────────────────────
# DOEH Loyalty Template — environment
# Copy to `.env` (gitignored) and fill in. EXPO_PUBLIC_* values are INLINED into
# the app binary at build time, so they are trivially extractable by anyone who
# downloads the app. Read docs/PRODUCTION.md before you ship.
# ─────────────────────────────────────────────────────────────────────────────

# sandbox | production
EXPO_PUBLIC_ENV=sandbox

# SANDBOX ONLY — a test key may be embedded for clone-and-run. Sandbox data is
# isolated, reset daily, and carries no real money/PII. NEVER put an sk_live_
# key here: it would ship a shop-wide secret to every downloader. Leave unset
# to paste the key in-app instead (stored in the device secure store).
EXPO_PUBLIC_DOEH_API_KEY=

# PRODUCTION ONLY — base URL of YOUR token broker (see docs/PRODUCTION.md).
# The app exchanges a device session for a short-lived token here; the broker
# holds sk_live_ server-side. Not implemented in v1 scaffold (M5).
EXPO_PUBLIC_BROKER_URL=
