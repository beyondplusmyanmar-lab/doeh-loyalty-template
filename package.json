{
  "name": "doeh-loyalty-template",
  "version": "0.1.0",
  "private": true,
  "description": "Clone-and-own merchant loyalty app for the DOEH platform — SDK-first, brandable, store-publishable.",
  "main": "expo-router/entry",
  "scripts": {
    "bootstrap": "node scripts/bootstrap.mjs",
    "doctor": "node scripts/doctor.mjs",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "validate:brand": "node scripts/validate-brand.mjs",
    "smoke:loyalty": "node scripts/loyalty.smoke.mjs",
    "check": "pnpm validate:brand && pnpm typecheck"
  },
  "dependencies": {
    "@beyondplusmm/doehpos-sdk": "^0.4.0",
    "@tanstack/react-query": "^5.59.16",
    "expo": "~52.0.11",
    "expo-constants": "~17.0.3",
    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.9",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "ajv": "^8.17.1",
    "typescript": "^5.6.3"
  }
}
